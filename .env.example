# PostgreSQL — host must be a real DNS name (e.g. from Render: "External Database URL").
# Bad:  ...@dpg-xxxxx-a/dbname          → only a fragment, DNS will fail locally.
# Good: ...@dpg-xxxxx-a.<region>-postgres.render.com/dbname?sslmode=require
# Copy the full string from Render Dashboard → PostgreSQL → Connections → External URL.
DATABASE_URL=postgresql://USER:PASSWORD@dpg-xxxxx-a.ohio-postgres.render.com/DBNAME?sslmode=require

SECRET_KEY=replace-with-a-long-random-secret

# Optional: your web service URL on Render (keep-alive ping). Omit for pure local dev.
RENDER_EXTERNAL_URL=https://your-render-service.onrender.com
